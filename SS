<p>Phone 1</p>
<p class="red">404-397-3680</p>

<p>Phone 2</p>
<p class="red">910-214-3264</p>

<a class="btn btn-red" href="tel:4043973680">Call 404-397-3680</a>
<a class="btn btn-outline" href="https://instagram.com/ArvexAutoSpa">Instagram</a>

</div>

<script>
function setLang(lang){
if(lang==="es"){
document.getElementById("title").innerText="ARVEX AUTO SPA";
document.getElementById("desc").innerText="Página oficial de Arvex Auto Spa. Servicio moderno de detailing móvil y lavado básico.";
}else{
document.getElementById("title").innerText="ARVEX AUTO SPA";
document.getElementById("desc").innerText="Official page for Arvex Auto Spa. Modern mobile detailing and basic wash service.";
}
}
</script>

</body>
</html>
