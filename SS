<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arvex Auto Spa</title>

<style>
body{
margin:0;
font-family:Arial, sans-serif;
background:#0b0b0b;
color:white;
}

.container{
width:90%;
max-width:1100px;
margin:auto;
}

h1,h2,h3{
margin:0;
}

.hero{
text-align:center;
padding:40px 0;
}

.hero img{
max-width:420px;
width:100%;
margin-bottom:20px;
}

.btn{
display:inline-block;
padding:12px 20px;
border-radius:25px;
margin:10px;
font-weight:bold;
text-decoration:none;
}

.btn-red{
background:red;
color:white;
}

.btn-outline{
border:1px solid white;
color:white;
}

.section{
padding:40px 0;
}

.cards{
display:flex;
flex-wrap:wrap;
gap:20px;
}

.card{
flex:1;
min-width:250px;
background:#151515;
padding:20px;
border-radius:15px;
}

.price{
font-size:22px;
font-weight:bold;
margin:10px 0;
}

.red{
color:red;
font-weight:bold;
}

.center{
text-align:center;
}

.toggle{
position:fixed;
top:10px;
right:10px;
}

</style>
</head>

<body>

<div class="toggle">
<button onclick="setLang('en')">EN</button>
<button onclick="setLang('es')">ES</button>
</div>

<!-- HERO -->
<div class="hero container">
